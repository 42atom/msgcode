# msgcode 配置文件
#
# 推荐使用 msgcode init 命令自动创建此文件
# 也可手动复制到 ~/.config/msgcode/.env 后编辑

# ============================================
# 使用者信息（白名单）
# ============================================
# 你的主邮箱（白名单；至少配置一项）
MY_EMAIL=

# 电话号码（可选）
# MY_PHONE=+8613800138000

# ============================================
# 飞书主通道（默认推荐）
# ============================================
# 飞书企业自建应用凭据（默认 feishu transport 必需）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 群聊安全（可选）：只响应“你自己的账号”（收口信任边界）
#
# - 不改变 Codex 的 sandbox 权限（仍可 danger-full-access），只限制“谁能触发执行”
# - 仅对群聊生效（chatId 形如 any;+;... 或 32 位 GUID）
# - MSGCODE_OWNER 支持逗号分隔多个标识（邮箱/电话 handle），但建议只填主号
#
# MSGCODE_OWNER_ONLY_IN_GROUP=1
# MSGCODE_OWNER=wan2011@me.com

# ============================================
# 工作空间根目录（2.0 推荐）
# ============================================
# 2.0 的工作目录统一挂在 root 下，每个群聊在群里用 /bind <dir> 绑定。
# 默认值：~/msgcode-workspaces
WORKSPACE_ROOT=/Users/<you>/msgcode-workspaces

# HuggingFace 缓存目录（建议放用户配置目录，避免写回仓库）
HF_HOME=/Users/<you>/.config/msgcode/cache/hf

# ============================================
# 群组路由配置（legacy，可选）
# ============================================
# 仅用于兼容旧的“静态绑定”模式：GROUP_<群组名>=<chatGuid>:<项目路径>:<bot类型>
# 2.0 推荐在群里用 /bind，而不是写 GROUP_*。
#
# 示例（chat guid）：
# GROUP_CODE_BOT=feishu:oc_xxx:/Users/<you>/path/to/project:code

# ============================================
# 日志配置
# ============================================
# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info

# 日志文件路径（可选）
# LOG_PATH=~/.config/msgcode/log/msgcode.log

# 禁用文件日志（可选）
# LOG_FILE=false

# 调试开关：记录入站消息明文到日志（默认关闭，含敏感信息）
# MSGCODE_LOG_PLAINTEXT_INPUT=0

# ============================================
# 高级配置（可选）
# ============================================

# 长任务回执延迟（毫秒，可选）
# - 非 slash 消息超过该时长才发送回执（默认 15000）
# - 设为 0 表示立即回执（不推荐，太吵）
# MSGCODE_ACK_DELAY_MS=15000

# 远程沟通提示（可选）：注入到 Codex/Claude Code 的第一条消息前缀
# - 目的：提醒模型“用户在移动端远程沟通”，回答应更短、更可复制
# - 默认开启；设为 0 可关闭
# MSGCODE_REMOTE_HINT=1
# 可选：自定义提示文本（多行不建议写这里；如需多行可写在外部文件再读入）
# MSGCODE_REMOTE_HINT_TEXT=【远程上下文｜勿复述】用户正在移动端远程沟通...
# ============================================
# 本地模型（可选：LM Studio）
# ============================================
# 当你在群里绑定 botType=lmstudio 时（/bind <dir> lmstudio），msgcode 会调用 LM Studio 的本地 API。
#
# 你需要在 LM Studio 里启动 Local Server（同一个 Server 同时支持原生 REST `/api/v1/*` 与 OpenAI 兼容 `/v1/*`），默认地址：
# http://127.0.0.1:1234
#
# 本地 API Base URL（可选）
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234
#
# 模型名（可选）
# - 留空：优先使用 `huihui-glm-4.7-flash-abliterated-mlx`（若已加载），否则回退到当前已加载模型
# - 设为 "auto"：使用 LM Studio 当前已加载的模型（推荐做兼容回退）
# - 设为具体模型名：使用指定模型（LM Studio 会自动加载，可能导致启动新模型）
# LMSTUDIO_MODEL=huihui-glm-4.7-flash-abliterated-mlx
#
# 视觉模型（可选，read-images/vision 工具链使用）
# - 留空时默认：huihui-glm-4.6v-flash-abliterated-mlx
# LMSTUDIO_VISION_MODEL=huihui-glm-4.6v-flash-abliterated-mlx
#
# API Key（可选；LM Studio 开启认证后需要）
# LMSTUDIO_API_KEY=<your-api-token>
#
# System Prompt（可选；默认不注入，避免绑定角色/行为）
# AGENT_SYSTEM_PROMPT=<optional>
#
# System Prompt 文件（可选；用于反复调试提示词）
# - 优先级：AGENT_SYSTEM_PROMPT > AGENT_SYSTEM_PROMPT_FILE > prompts/agents-prompt.md（默认）
# - 支持绝对路径或相对项目根路径
# AGENT_SYSTEM_PROMPT_FILE=prompts/agents-prompt.md
#
# 请求超时（毫秒，可选，默认 120000）
# LMSTUDIO_TIMEOUT_MS=120000
#
# 最大输出 token（可选，默认 4000）
# LMSTUDIO_MAX_TOKENS=4000

# ============================================
# Agent Backend（多后端切换，可选）
# ============================================
# 目标：支持同一条 agent 链路切换不同后端（本地 LM Studio / MiniMax / OpenAI）
#
# 可选值：
# - local-openai / agent-backend / lmstudio  -> 本地兼容后端（默认）
# - minimax                                  -> MiniMax Anthropic-compatible（推荐）
# - openai                                   -> OpenAI API
# AGENT_BACKEND=local-openai
#
# 通用后端参数（未设置时会回退到各后端专用变量）
# AGENT_BASE_URL=
# AGENT_MODEL=
# AGENT_API_KEY=
# AGENT_TIMEOUT_MS=120000
#
# MiniMax 后端专用（启用 AGENT_BACKEND=minimax 时优先）
# MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# MINIMAX_BASE_URL=
# MINIMAX_MODEL=
# MINIMAX_API_KEY=
# MINIMAX_TIMEOUT_MS=120000
#
# OpenAI 后端专用（启用 AGENT_BACKEND=openai 时优先）
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# OPENAI_TIMEOUT_MS=120000

# ============================================
# 语音（TTS，可选）
# ============================================
# 自动语音回复时，最多朗读的字符数（避免超长回复导致生成时间过久）
# 默认 240；你可以根据机器性能调大（例如 800/1800）
# TTS_AUTO_MAX_CHARS=240

# 语音转码时是否裁切静音（默认 1 开启；0 关闭）
# - 开启可避免移动端播放器播放尾部出现“长空白”
# - 若你发现“只读第一句/后面被切掉”，先尝试调低阈值或延长 stop_duration
# TTS_TRIM_SILENCE=1

# 静音阈值（越小越保守，越不容易误切）
# 推荐：-60dB（默认）；如果仍有长空白可试 -50dB；如果被切掉可试 -65dB
# TTS_SILENCE_DB=-60dB

# 尾部静音判定“最小持续时长”（秒），越大越不容易把“句间停顿”当作尾部静音
# 推荐：2.0（默认）
# TTS_SILENCE_MIN_DURATION_SEC=2.0

# 输出增益（dB，可选）：让语音更响
# - 建议从 3 开始试；太大可能爆音/失真
# TTS_OUTPUT_GAIN_DB=3

# ============================================
# Qwen3-TTS（本地，可选；当前唯一正式 TTS 后端）
# ============================================
# 严格指定当前 lane 使用 qwen；留空时为 auto:qwen
# TTS_BACKEND=qwen
#
# 安装位置（默认：~/Models/qwen3-tts-apple-silicon）
# QWEN_TTS_ROOT=~/Models/qwen3-tts-apple-silicon
# QWEN_TTS_PYTHON=$QWEN_TTS_ROOT/.venv/bin/python
#
# 模型目录（留空时走默认）
# QWEN_TTS_MODEL_CUSTOM=$QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit
# QWEN_TTS_MODEL_CLONE=$QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-Base-8bit
#
# 可选：克隆模式参考音频/文字
# - 设置 QWEN_TTS_REF_AUDIO 后会走 clone 模式
# - 建议用 m4a/wav；内部会自动转成 wav
# QWEN_TTS_REF_AUDIO=
# QWEN_TTS_REF_TEXT=
#
# 可选：CustomVoice 默认参数
# QWEN_TTS_VOICE=Vivian
# QWEN_TTS_INSTRUCT=Normal tone
# QWEN_TTS_SPEED=1.0
# QWEN_TTS_LANG_CODE=

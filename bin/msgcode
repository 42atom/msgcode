#!/usr/bin/env node
/**
 * msgcode CLI 可执行文件
 */

import { spawn } from "child_process";
import { fileURLToPath } from "url";
import { dirname, join } from "path";
import { existsSync } from "fs";

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);

const runtimeRoot = process.env.MSGCODE_RUNTIME_ROOT?.trim()
    ? process.env.MSGCODE_RUNTIME_ROOT.trim()
    : "";
const explicitCliEntry = process.env.MSGCODE_CLI_ENTRY?.trim() || "";
const compiledCandidates = [
    explicitCliEntry,
    runtimeRoot ? join(runtimeRoot, "app", "cli.js") : "",
    runtimeRoot ? join(runtimeRoot, "dist", "cli.js") : "",
].filter(Boolean);

const compiledCliEntry = compiledCandidates.find((candidate) => existsSync(candidate));
let command;
let args;

if (compiledCliEntry) {
    command = process.execPath;
    args = [compiledCliEntry, ...process.argv.slice(2)];
} else {
    const cliPath = join(__dirname, "..", "src", "cli.ts");
    const localTsxCli = join(__dirname, "..", "node_modules", "tsx", "dist", "cli.mjs");
    command = existsSync(localTsxCli) ? process.execPath : "npx";
    args = existsSync(localTsxCli)
        ? [localTsxCli, cliPath, ...process.argv.slice(2)]
        : ["tsx", cliPath, ...process.argv.slice(2)];
}

const child = spawn(command, args, {
    stdio: "inherit",
});

process.on("SIGINT", () => child.kill("SIGINT"));
process.on("SIGTERM", () => child.kill("SIGTERM"));

child.on("exit", (code) => {
    process.exit(code ?? 0);
});

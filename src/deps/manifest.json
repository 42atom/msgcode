{
  "version": 1,
  "requiredForStart": [],
  "requiredForJobs": [
    {
      "id": "tmux",
      "kind": "bin",
      "cmd": "tmux -V"
    }
  ],
  "optional": [
    {
      "id": "imsg",
      "kind": "bin",
      "pathEnv": "IMSG_PATH",
      "description": "iMessage transport 可执行入口（仅在启用 imsg 时需要）"
    },
    {
      "id": "messages_db",
      "kind": "fs_read",
      "path": "~/Library/Messages/chat.db",
      "description": "macOS iMessage 本地 chat.db（仅在启用 imsg 时需要）"
    },
    {
      "id": "lmstudio",
      "kind": "http",
      "url": "http://127.0.0.1:1234/v1/models",
      "description": "LM Studio API（可通过 LMSTUDIO_BASE_URL 覆盖）"
    },
    {
      "id": "mlx_whisper",
      "kind": "bin",
      "cmd": "mlx-whisper --help"
    },
    {
      "id": "whisper_model",
      "kind": "fs_exists",
      "path": "~/Models/whisper-large-v3-mlx"
    },
    {
      "id": "sips",
      "kind": "bin",
      "cmd": "sips --version"
    },
    {
      "id": "lmstudio_vision_model",
      "kind": "model_loaded",
      "description": "LM Studio Vision 模型（推荐: GLM-4.6V，如 huihui-glm-4.6v-flash-abliterated-mlx）"
    },
    {
      "id": "codex",
      "kind": "bin",
      "cmd": "codex --version",
      "description": "Codex CLI（执行臂，需要 egress-allowed）"
    },
    {
      "id": "qwen_tts_python",
      "kind": "bin",
      "pathEnv": "QWEN_TTS_PYTHON",
      "description": "Qwen TTS Python（建议: $QWEN_TTS_ROOT/.venv/bin/python）"
    },
    {
      "id": "qwen_tts_custom_model",
      "kind": "fs_exists",
      "path": "$QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit",
      "description": "Qwen TTS CustomVoice 模型目录（默认: $QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit）"
    },
    {
      "id": "qwen_tts_clone_model",
      "kind": "fs_exists",
      "path": "$QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-Base-8bit",
      "description": "Qwen TTS Clone 模型目录（默认: $QWEN_TTS_ROOT/models/Qwen3-TTS-12Hz-0.6B-Base-8bit）"
    }
  ]
}
